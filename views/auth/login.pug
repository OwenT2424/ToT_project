extends ../layout

block content
  .auth-wrap
    h1.auth-title Welcome back.
    p.auth-sub Sign in to continue your story.

    .alert.alert-error#error-msg

    .form-group
      label.form-label(for="email") Email
      input.form-input#email(type="email" name="email" autocomplete="email" autofocus)

    .form-group
      label.form-label(for="password") Password
      input.form-input#password(type="password" name="password" autocomplete="current-password")

    .btn-row
      button.btn.btn-primary#submit-btn(type="button") Sign in

    p.auth-footer
      | Don't have an account? &nbsp;
      a(href="/auth/register") Join here

block scripts
  script.
    document.getElementById('submit-btn').addEventListener('click', async () => {
      const email = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;
      const errorEl = document.getElementById('error-msg');
      errorEl.classList.remove('visible');

      const res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ email, password })
      });
      const data = await res.json();

      if (res.ok) {
        window.location.href = '/stories';
      } else {
        errorEl.textContent = data.error || 'Login failed.';
        errorEl.classList.add('visible');
      }
    });

    // Allow Enter key to submit
    document.addEventListener('keydown', e => {
      if (e.key === 'Enter') document.getElementById('submit-btn').click();
    });
